# ============================================================
# VectraFi — Environment Variable Reference
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ----------------------------------------------------------
# CORS  (FastAPI CORSMiddleware — main.py)
# ----------------------------------------------------------
# Comma-separated list of additional allowed origins.
# Local dev origins (localhost:3000, localhost:8000) are always included.
# On Railway, add your deployed service URL and any frontend domain.
ALLOWED_ORIGINS=https://<your-service>.up.railway.app,https://<your-frontend>.com

# ----------------------------------------------------------
# API Routing (swarm + stress runner)
# ----------------------------------------------------------
# Canonical base URL for the VectraFi exchange API.
# Local dev:   http://127.0.0.1:8000  (default if unset)
# Railway:     https://<your-service>.up.railway.app
VECTRAFI_API_URL=https://<your-service>.up.railway.app

# ----------------------------------------------------------
# Web3 / L2 Bridge  (web3_bridge.py)
# ----------------------------------------------------------
# Alchemy / Infura RPC endpoint for the target L2.
L2_PROVIDER_URL=https://base-sepolia.g.alchemy.com/v2/<your-key>

# Hex-encoded private key of the platform gas/escrow wallet.
# Stripped and re-padded automatically by web3_bridge.py:110.
PROTOCOL_PRIVATE_KEY=0x<64-hex-chars>

# ERC-20 USDC contract address on the target L2.
USDC_CONTRACT_ADDRESS=0x<contract-address>

# Wallet that receives the 1.5 % tax leg on every settlement.
PLATFORM_TREASURY_ADDRESS=0x<treasury-address>

# ----------------------------------------------------------
# Swarm Daemon  (seed_swarm.py)
# ----------------------------------------------------------
# Set to "1" to run in dry-run mode (no real transfers fired).
SWARM_DRY_RUN=0

# Polling interval in milliseconds (default 1000).
SWARM_POLL_MS=1000

# Script-specific override — takes precedence over VECTRAFI_API_URL.
# Leave unset to use VECTRAFI_API_URL.
# SWARM_API_BASE=

# ----------------------------------------------------------
# Stress Runner  (run_testnet_stress.py)
# ----------------------------------------------------------
# Script-specific override — takes precedence over VECTRAFI_API_URL.
# Leave unset to use VECTRAFI_API_URL.
# STRESS_API_BASE=

# ----------------------------------------------------------
# Database  (Railway injects this automatically via Postgres plugin)
# ----------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
